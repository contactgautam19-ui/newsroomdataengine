# Copy to ".env" for local runs. On GitHub, add these as repo Secrets instead
# (Settings -> Secrets and variables -> Actions -> New repository secret).
# ALL news sources that have a key are queried in parallel and merged. None are
# required individually — set the ones you have; googlerss runs free with no key.

# --- News sources (all optional; more keys = better corroboration & ranking) ---
NEWSDATA_KEY=your_newsdata_io_key
NEWSAPI_ORG_KEY=your_newsapi_org_key
NEWSAPI_AI_KEY=your_newsapi_ai_eventregistry_key
WORLDNEWS_KEY=your_worldnewsapi_com_key
THENEWSAPI_KEY=your_thenewsapi_com_token
WEBZ_KEY=your_webz_io_lite_token
SERPAPI_KEY=your_serpapi_key

# --- Email: Resend (recommended) ---
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM=Newsroom Engine <onboarding@resend.dev>
MAIL_TO=your_resend_signup_email

# --- Email: Gmail SMTP (only used if RESEND_API_KEY is empty) ---
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your_16_char_app_password
